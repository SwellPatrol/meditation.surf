{
  "name": "@meditation-surf/workspace",
  "version": "1.0.0",
  "type": "module",
  "description": "Stunning surf cinematography from SwellPatrol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SwellPatrol/meditation.surf.git"
  },
  "homepage": "https://meditation.surf",
  "bugs": {
    "url": "https://github.com/SwellPatrol/meditation.surf/issues"
  },
  "author": "Garrett Brown <eigendebugger@gmail.com>",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "calm",
    "environment",
    "health",
    "meditation",
    "mindfulness",
    "nature",
    "ocean",
    "peace",
    "relaxation",
    "serenity",
    "spirituality",
    "surf",
    "surfing",
    "tranquility",
    "water",
    "waves",
    "wellness",
    "zen"
  ],
  "scripts": {
    "audit-ci": "audit-ci --config audit-ci.json",
    "build": "pnpm build:tsc && pnpm build:tv && pnpm build:mobile && pnpm build:web",
    "build:ios": "pnpm --dir apps/mobile-expo build:ios",
    "build:mobile": "pnpm --dir apps/mobile-expo build",
    "build:tsc": "tsc --project tsconfig.json",
    "build:tv": "pnpm --dir apps/tv-lightning build",
    "build:web": "pnpm --dir apps/web-vite build",
    "check": "pnpm install --frozen-lockfile && pnpm audit-ci && pnpm format && pnpm build && pnpm test",
    "clean": "rm -rf node_modules packages/core/node_modules packages/player-core/node_modules && pnpm clean:ios && pnpm clean:mobile && pnpm clean:tv && pnpm clean:web",
    "clean:ios": "rm -rf apps/mobile-expo/ios",
    "clean:mobile": "rm -rf apps/mobile-expo/.expo apps/mobile-expo/.expo-shared apps/mobile-expo/dist apps/mobile-expo/node_modules apps/mobile-expo/web-build",
    "clean:tv": "rm -rf apps/tv-lightning/dist apps/tv-lightning/node_modules",
    "clean:web": "rm -rf apps/web-vite/dist apps/web-vite/node_modules",
    "deploy": "pnpm build && gh-pages --branch main --repo git@github.com-eigendude:SwellPatrol/swellpatrol.github.io.git --dist apps/tv-lightning/dist --dotfiles",
    "dev": "concurrently --kill-others --names tv,mobile,web,ios \"pnpm dev:tv\" \"pnpm dev:mobile\" \"pnpm dev:web\" \"pnpm dev:ios\"",
    "dev:ios": "pnpm --dir apps/mobile-expo dev:ios",
    "dev:mobile": "pnpm --dir apps/mobile-expo dev",
    "dev:tv": "pnpm --dir apps/tv-lightning dev",
    "dev:web": "pnpm --dir apps/web-vite dev",
    "format": "prettier --write . && eslint --fix .",
    "format:eslint": "eslint --fix .",
    "format:prettier": "prettier --write .",
    "lint": "pnpm lint:prettier && pnpm lint:eslint",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "preview": "pnpm --dir apps/tv-lightning exec vite preview",
    "start": "pnpm dev",
    "test": "vitest run --passWithNoTests",
    "test:ui": "vitest --ui"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lightningjs/msdf-generator": "^1.2.0",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "audit-ci": "^7.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "gh-pages": "^6.3.0",
    "prettier": "^3.8.1",
    "prettier-plugin-pkg": "^0.22.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.7",
    "vitest": "^4.1.3"
  },
  "resolutions": {
    "file-type": "22.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.83.4",
    "react-native-renderer": "19.2.4"
  }
}
